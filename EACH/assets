              <div class="agent-role">Routes via<br>handoff tools</div>
              <div class="agent-tag">entry node</div>
            </div>
            <div class="agent-node">
              <div class="agent-chip" style="background:linear-gradient(135deg,#0B7B74,#065F5A);">🔍</div>
              <div class="agent-name">Assessment</div>
              <div class="agent-role">Gathers 4 fields<br>ReAct loop</div>
              <div class="agent-tag">FIELD_COLLECTED</div>
            </div>
            <div class="agent-node">
              <div class="agent-chip" style="background:linear-gradient(135deg,#7B3F9E,#5E2D80);">📋</div>
              <div class="agent-name">Planning</div>
              <div class="agent-role">Generates<br>5-day plan</div>
              <div class="agent-tag">PLAN_GENERATED</div>
            </div>
            <div class="agent-node">
              <div class="agent-chip" style="background:linear-gradient(135deg,#C9622A,#A54D1E);">🪞</div>
