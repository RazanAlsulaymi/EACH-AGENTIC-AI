          Leen Alhazmi<br>
          Nada Alomar<br>
          Razan Alsulaymi
        </div>
      </div>
    </div>
  </header>

  <!-- BODY -->
  <div class="body">

    <!-- SIDEBAR -->
    <div class="sidebar">

      <!-- Problem Stats -->
      <div>
        <div class="sec-label">The Problem</div>
        <div class="problem-box">
          <div class="stat-row">
            <span class="stat-num">3–5</span>
            <span class="stat-label">hours/week on manual<br>lesson planning</span>
          </div>
          <div class="divider"></div>
          <div class="stat-row">
            <span class="stat-num">0</span>
            <span class="stat-label">Arabic AI tools for<br>special education</span>
          </div>
          <div class="divider"></div>
          <div class="stat-row">
            <span class="stat-num">4</span>
            <span class="stat-label">diagnoses served with<br>no unified platform</span>
          </div>
        </div>
      </div>

      <!-- Survey -->
      <div>
        <div class="sec-label">Field Survey · 28 Stakeholders</div>
        <div class="survey-box">
          <div class="bar-row">
            <div class="bar-meta">
              <span class="bar-name">Would use weekly</span>
              <span class="bar-pct">63%</span>
            </div>
            <div class="bar-track"><div class="bar-fill" style="width:63%;background:var(--teal);"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-meta">
              <span class="bar-name">Rate as very important</span>
              <span class="bar-pct">63%</span>
            </div>
            <div class="bar-track"><div class="bar-fill" style="width:63%;background:var(--agent-2);"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-meta">
              <span class="bar-name">Need bilingual support</span>
              <span class="bar-pct">90%</span>
            </div>
            <div class="bar-track"><div class="bar-fill" style="width:90%;background:var(--gold);"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-meta">
              <span class="bar-name">Plan generation &lt; 5 min</span>
              <span class="bar-pct">Target</span>
            </div>
            <div class="bar-track"><div class="bar-fill" style="width:100%;background:var(--agent-5);"></div></div>
          </div>
        </div>
      </div>

      <!-- Out of Scope -->
      <div>
        <div class="sec-label">Scope Boundaries</div>
        <div class="scope-badges">
          <div class="scope-item"><span class="scope-check">✓</span> Lesson plan generation</div>
          <div class="scope-item"><span class="scope-check">✓</span> IEP document analysis (OCR)</div>
          <div class="scope-item"><span class="scope-check">✓</span> Voice + file input</div>
